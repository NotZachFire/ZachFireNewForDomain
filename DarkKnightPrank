<!DOCTYPE html>
<html>
<head>
<title>Help!</title>
<link rel="icon" type="image/png" href="MySymbol.png">

<style>
  @keyframes flicker {
    0% { opacity: 1; }
    50% { opacity: 0.5; }
    100% { opacity: 1; }
  }

body { font-family: monospace; background: #111; color: #0f0; padding: 20px; text-shadow: 0 0 10px #00ff00; cursor: url("data:image/svg+xml,%3Csvg width='24' height='24' viewBox='0 0 24 24' fill='none' xmlns='http://www.w3.org/2000/svg'%3E%3Cpath d='M12 2V22M2 12H22' stroke='red' stroke-width='2'/%3E%3C/svg%3E") 12 12, crosshair;
 }
input, textarea, button { font-family: monospace; font-size: 15px; margin: 7px 0; width: 100%; animation: flicker 2s infinite; }
button { cursor: pointer; }
</style>

</head>
<body>
<h2>Help!</h2>


<h1 style="color: lime; animation: flicker 2s infinite;"> Click to get me out of here! I'm stuck in a cave, fighting with a half broken blade... ooh that rhymed, didn't it? HELP! </h1>


<button onclick="changeText()">Please click to save me!</button>
<h1 id="output"></h1>
<script>
function changeText() {
let name = "Wow...";
document.getElementById("output").textContent = name + " you really fell for that didn't you! Thanks for the money!";
}
document.addEventListener('keydown', function(event) {
  if (event.key === 'z' || event.key === 'Z') {
    document.body.style.backgroundColor = "#500"; 
    document.getElementById("output").textContent = "ZACHARY'S SECRET MODE ACTIVATED!";
    document.getElementById("output").style.color = "orange";
  }
});

</script>
<img src="DarkKnight.jpg" 
     style="display: block; margin: 0 auto; max-height: 80vh; width: auto;">


</body>
</html>
